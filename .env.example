# Vercel KV (session storage)
# Get these from your Vercel project dashboard → Storage → KV
KV_REST_API_URL=
KV_REST_API_TOKEN=

# BaaS fallback (Browserbase)
# Required when confidence < 0.8
BROWSERBASE_API_KEY=

# Session TTL in seconds (default: 3600 = 1 hour)
SESSION_TTL_SECONDS=3600

# Viewport defaults
HOLLOW_VIEWPORT_WIDTH=1280
HOLLOW_VIEWPORT_HEIGHT=800
